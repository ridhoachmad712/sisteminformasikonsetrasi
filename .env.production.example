# ============================================================
# KONFIGURASI PRODUCTION — Salin ke .env saat deploy ke hosting
# ============================================================

APP_NAME="SINIKO"
APP_ENV=production
APP_KEY=         # php artisan key:generate
APP_DEBUG=false  # WAJIB false di production!
APP_URL=https://domain-anda.ac.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=id

# ─── Database ───────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost    # di cPanel biasanya localhost
DB_PORT=3306
DB_DATABASE=nama_database_cpanel
DB_USERNAME=user_database_cpanel
DB_PASSWORD=password_database_cpanel

# ─── Cache & Session ────────────────────────────────────────
# Gunakan 'file' jika cPanel tidak punya Redis
# Gunakan 'database' jika ingin lebih aman (sudah ada tabel cache)
CACHE_STORE=file
SESSION_DRIVER=database
SESSION_LIFETIME=180     # 3 jam (perpanjang dari default 2 jam)
SESSION_ENCRYPT=false

# ─── Queue ──────────────────────────────────────────────────
QUEUE_CONNECTION=sync    # 'sync' untuk shared hosting (tidak ada worker)

# ─── Security ───────────────────────────────────────────────
BCRYPT_ROUNDS=10         # Turunkan dari 12 ke 10 untuk hemat CPU
                         # (masih aman, login lebih cepat ~50ms vs 100ms)

# ─── Log ────────────────────────────────────────────────────
LOG_CHANNEL=single
LOG_LEVEL=error          # Hanya log error, kurangi I/O disk

# ─── Mail (opsional) ────────────────────────────────────────
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=email@gmail.com
# MAIL_PASSWORD=app_password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=email@gmail.com
# MAIL_FROM_NAME="SINIKO"
